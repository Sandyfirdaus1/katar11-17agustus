# WAJIB — salin dari MongoDB Atlas → Connect → Drivers
# Contoh: mongodb+srv://username:password@cluster.mongodb.net/katar11-lomba?retryWrites=true&w=majority
MONGODB_URI=

# Secret untuk JWT login admin (wajib diganti, minimal 32 karakter)
JWT_SECRET=ganti-dengan-secret-key-yang-kuat-minimal-32-karakter

# Akun admin pertama (hanya dipakai saat seed data awal)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti-password-admin-yang-kuat

# Wajib di Vercel production untuk menjalankan seed API
# Kirim header: Authorization: Bearer <SEED_SECRET>
SEED_SECRET=ganti-dengan-token-seed-yang-rahasia
